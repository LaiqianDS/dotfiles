{
    "[python]": {
        "editor.formatOnType": true
    },
    "workbench.preferredLightColorTheme": "Default Dark+",
    "git.openRepositoryInParentFolders": "never",
    "terminal.external.osxExec": "Ghostty.app",
    "terminal.explorerKind": "external",
    "terminal.integrated.enableMultiLinePasteWarning": "auto",
    "editor.minimap.enabled": false,
    "editor.rulers": [
        {"column": 79, "color": "#002aff6a" },
        {"column": 120, "color": "#002affc4" }
    ],
    "editor.wordWrap": "on",
    "notebook.lineNumbers": "on",
    "workbench.editor.enablePreview": false,
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
    "editor.fontLigatures": true,
    "editor.fontWeight": "normal",
    "editor.fontSize": 14,
    "workbench.settings.applyToAllProfiles": [


    ],
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.xlsx": "default"
    },
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "jupyter.askForKernelRestart": false,
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "github.copilot.selectedCompletionModel": "gpt-4o-copilot",
    "terminal.integrated.suggest.enabled": true,
    "git.confirmSync": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "python.languageServer": "Default",
    "yaml.schemas": {
        "file:///Users/laiqiands/.vscode/extensions/atlassian.atlascode-3.8.16/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "ruff.lineLength": 79,
    "todo-tree.general.showActivityBarBadge": true,
    "workbench.colorTheme": "One Dark Pro",
    "editor.formatOnType": true,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "workbench.preferredDarkColorTheme": "One Dark Pro",
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 12,
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.hidesExplorerArrows": true,
    "chat.viewSessions.orientation": "stacked",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "explorer.compactFolders": false,
    "explorer.decorations.badges": false,
    "editor.lightbulb.enabled": "off",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "solid",
    "editor.renderLineHighlight": "none",
    "editor.renderWhitespace": "none",
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.overviewRulerBorder": true,
    "editor.hideCursorInOverviewRuler": true,
    "editor.tabCompletion": "on",
}
